[Unit]
Description=BrainSession PWA HTTPS
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/myagent/.ductor/workspace/external/Brainsession_pwa
ExecStart=/usr/bin/env bash /home/myagent/.ductor/workspace/external/Brainsession_pwa/scripts/start-https.sh
Restart=always
RestartSec=5
Environment=HOST=0.0.0.0

[Install]
WantedBy=default.target
